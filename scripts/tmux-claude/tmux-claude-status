#!/usr/bin/env python3

import json
import os
import sys
from pathlib import Path
from typing import Optional

HOME = Path.home()
CLAUDE_DIR = HOME / ".claude"
SESSIONS_DIR = CLAUDE_DIR / "sessions"
PROJECTS_DIR = CLAUDE_DIR / "projects"
DEFAULT_CONTEXT_WINDOW = 200_000
MODEL_CONTEXT_WINDOWS = {
    "claude-opus-4-5": 200_000,
    "claude-opus-4-6": 1_000_000,
    "claude-sonnet-4-5": 200_000,
    "claude-sonnet-4-6": 200_000,
    "claude-haiku-4-5": 200_000,
}
METER_GLYPHS = "▁▂▃▄▅▆▇█"
SEGMENT_FG = "#e4e4e4"


def context_window_for_model(model: str) -> int:
    if model in MODEL_CONTEXT_WINDOWS:
        return MODEL_CONTEXT_WINDOWS[model]
    # prefix match for versioned model IDs like claude-opus-4-6-20251201
    for prefix, window in MODEL_CONTEXT_WINDOWS.items():
        if model.startswith(prefix):
            return window
    return DEFAULT_CONTEXT_WINDOW


def format_compact(value: int) -> str:
    if value >= 1_000_000:
        return f"{round(value / 1_000_000)}M"
    if value >= 1_000:
        return f"{round(value / 1_000)}k"
    return str(value)


def render_meter(pct: float) -> str:
    clamped = max(0.0, min(pct, 100.0))
    index = min(int((clamped / 100.0) * len(METER_GLYPHS)), len(METER_GLYPHS) - 1)
    glyph = METER_GLYPHS[index]
    if clamped < 50.0:
        color = "colour46"
    elif clamped < 70.0:
        color = "colour214"
    else:
        color = "colour196"
    return f"#[fg={color}]{glyph}#[fg={SEGMENT_FG}]"


def pid_is_running(pid: str) -> bool:
    return pid.isdigit() and Path("/proc").joinpath(pid).exists()


def get_pid_ppid(pid: str) -> Optional[str]:
    try:
        for line in Path("/proc").joinpath(pid, "status").read_text().splitlines():
            if line.startswith("PPid:"):
                return line.split(":", 1)[1].strip()
    except OSError:
        return None
    return None


def is_descended_from(pid: str, ancestor_pid: str) -> bool:
    current = pid
    seen: set = set()
    while current and current not in seen and current != "1":
        if current == ancestor_pid:
            return True
        seen.add(current)
        current = get_pid_ppid(current) or ""
    return current == ancestor_pid


def is_in_focused_pane(pid: str, pane_pid: str) -> bool:
    if not (pid_is_running(pid) and pid_is_running(pane_pid)):
        return False
    try:
        if os.getsid(int(pid)) == int(pane_pid):
            return True
    except OSError:
        pass
    return is_descended_from(pid, pane_pid)


def find_active_session(preferred_pane_pid: Optional[str]) -> Optional[dict]:
    try:
        session_files = sorted(
            SESSIONS_DIR.glob("*.json"),
            key=lambda p: p.stat().st_mtime,
            reverse=True,
        )
    except OSError:
        return None

    preferred: list = []
    fallback: list = []

    for session_file in session_files:
        try:
            session = json.loads(session_file.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        pid = str(session.get("pid", ""))
        if not pid_is_running(pid):
            continue
        if preferred_pane_pid and is_in_focused_pane(pid, preferred_pane_pid):
            preferred.append(session)
        else:
            fallback.append(session)

    if preferred:
        return preferred[0]
    if preferred_pane_pid:
        return None
    if fallback:
        return fallback[0]
    return None


def find_project_jsonl(session: dict) -> Optional[Path]:
    session_id = session.get("sessionId")
    cwd = session.get("cwd", "")
    if not session_id or not cwd:
        return None
    project_key = cwd.replace("/", "-")
    jsonl = PROJECTS_DIR / project_key / f"{session_id}.jsonl"
    return jsonl if jsonl.exists() else None


def tail_text(path: Path, bytes_to_read: int = 65536) -> str:
    with path.open("rb") as handle:
        handle.seek(0, os.SEEK_END)
        size = handle.tell()
        handle.seek(max(0, size - bytes_to_read))
        return handle.read().decode("utf-8", errors="replace")


def get_context_from_jsonl(jsonl_path: Path) -> Optional[tuple]:
    try:
        text = tail_text(jsonl_path)
    except OSError:
        return None

    last_usage = None
    last_model = None
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            msg = obj.get("message")
            if not isinstance(msg, dict):
                continue
            usage = msg.get("usage")
            if not isinstance(usage, dict):
                continue
            if "input_tokens" in usage or "cache_read_input_tokens" in usage:
                last_usage = usage
                last_model = msg.get("model") or last_model
        except (json.JSONDecodeError, AttributeError):
            continue

    if last_usage is None:
        return None

    used = (
        last_usage.get("input_tokens", 0)
        + last_usage.get("cache_creation_input_tokens", 0)
        + last_usage.get("cache_read_input_tokens", 0)
    )
    if used == 0:
        return None
    total = context_window_for_model(last_model or "")
    return (used, total)


def get_context_segment(preferred_pane_pid: Optional[str]) -> Optional[str]:
    session = find_active_session(preferred_pane_pid)
    if session is None:
        return None
    jsonl_path = find_project_jsonl(session)
    if jsonl_path is None:
        return None
    result = get_context_from_jsonl(jsonl_path)
    if result is None:
        return None
    used, total = result
    pct = (used / total) * 100 if total else 0.0
    meter = render_meter(pct)
    return f"CTX {format_compact(used)}/{format_compact(total)} {meter} {pct:.0f}%"


def main() -> int:
    preferred_pane_pid = sys.argv[1] if len(sys.argv) > 1 else None
    segment = get_context_segment(preferred_pane_pid)
    if segment:
        print(segment)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
