#!/usr/bin/env python3

import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path
from typing import Optional


CACHE_TTL_SECONDS = 300
CONTEXT_HEADROOM_TOKENS = 32768
HOME = Path.home()
COPILOT_DIR = HOME / ".copilot"
SESSION_STATE_DIR = COPILOT_DIR / "session-state"
LOGS_DIR = COPILOT_DIR / "logs"
CACHE_DIR = HOME / ".cache" / "tmux-copilot-status"
CACHE_FILE = CACHE_DIR / "quota.json"
METER_GLYPHS = "▁▂▃▄▅▆▇█"
SEGMENT_FG = "#e4e4e4"

UTILIZATION_RE = re.compile(
    r"CompactionProcessor: Utilization (?P<pct>[0-9.]+)% "
    r"\((?P<used>\d+)/(?P<total>\d+) tokens\)"
)


def format_compact(value: int) -> str:
    if value >= 1_000_000:
        return f"{round(value / 1_000_000)}M"
    if value >= 1_000:
        return f"{round(value / 1_000)}k"
    return str(value)


def render_meter(pct: float) -> str:
    clamped_pct = max(0.0, min(pct, 100.0))
    index = min(int((clamped_pct / 100.0) * len(METER_GLYPHS)), len(METER_GLYPHS) - 1)
    glyph = METER_GLYPHS[index]
    if clamped_pct < 50.0:
        color = "colour46"
    elif clamped_pct < 70.0:
        color = "colour214"
    else:
        color = "colour196"
    return f"#[fg={color}]{glyph}#[fg={SEGMENT_FG}]"


def read_json(path: Path) -> Optional[dict]:
    try:
        return json.loads(path.read_text())
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return None


def write_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_suffix(".tmp")
    tmp_path.write_text(json.dumps(payload))
    tmp_path.replace(path)


def pid_is_running(pid: str) -> bool:
    return pid.isdigit() and Path("/proc").joinpath(pid).exists()


def get_pid_ppid(pid: str) -> Optional[str]:
    try:
        for line in Path("/proc").joinpath(pid, "status").read_text().splitlines():
            if line.startswith("PPid:"):
                return line.split(":", 1)[1].strip()
    except OSError:
        return None
    return None


def is_descended_from(pid: str, ancestor_pid: str) -> bool:
    current = pid
    seen = set()
    while current and current not in seen and current != "1":
        if current == ancestor_pid:
            return True
        seen.add(current)
        current = get_pid_ppid(current) or ""
    return current == ancestor_pid


def is_in_focused_pane(pid: str, pane_pid: str) -> bool:
    if not (pid_is_running(pid) and pid_is_running(pane_pid)):
        return False
    try:
        if os.getsid(int(pid)) == int(pane_pid):
            return True
    except OSError:
        pass
    return is_descended_from(pid, pane_pid)


def find_active_log(preferred_pane_pid: Optional[str] = None) -> Optional[Path]:
    try:
        lock_files = sorted(
            SESSION_STATE_DIR.glob("*/inuse.*.lock"),
            key=lambda path: path.stat().st_mtime,
            reverse=True,
        )
    except OSError:
        return None

    preferred_matches = []
    fallback_matches = []

    for lock_path in lock_files:
        pid = ""
        try:
            pid = lock_path.read_text().strip() or lock_path.stem.split(".", 1)[1]
        except (OSError, IndexError):
            continue
        if not pid_is_running(pid):
            continue
        matches = sorted(
            LOGS_DIR.glob(f"process-*-{pid}.log"),
            key=lambda path: path.stat().st_mtime,
            reverse=True,
        )
        if matches:
            match = matches[0]
            if preferred_pane_pid and is_in_focused_pane(pid, preferred_pane_pid):
                preferred_matches.append(match)
            else:
                fallback_matches.append(match)

    if preferred_matches:
        return preferred_matches[0]
    if preferred_pane_pid:
        return None
    if fallback_matches:
        return fallback_matches[0]
    return None


def tail_text(path: Path, bytes_to_read: int = 65536) -> str:
    with path.open("rb") as handle:
        handle.seek(0, os.SEEK_END)
        size = handle.tell()
        handle.seek(max(0, size - bytes_to_read))
        return handle.read().decode("utf-8", errors="replace")


def get_context_segment(preferred_pane_pid: Optional[str] = None) -> Optional[str]:
    log_path = find_active_log(preferred_pane_pid)
    if log_path is None:
        return None

    try:
        text = tail_text(log_path)
    except OSError:
        return None

    matches = list(UTILIZATION_RE.finditer(text))
    if not matches:
        return None

    match = matches[-1]
    used = int(match.group("used"))
    total = int(match.group("total"))
    display_total = total + CONTEXT_HEADROOM_TOKENS
    pct = (used / display_total) * 100 if display_total else 0.0
    meter = render_meter(pct)
    return f"CTX {format_compact(used)}/{format_compact(display_total)} {meter} {pct:.0f}%"


def fetch_quota_payload() -> Optional[dict]:
    env = dict(os.environ)
    env["GH_PAGER"] = "cat"
    env["PAGER"] = "cat"
    env["NO_COLOR"] = "1"
    try:
        result = subprocess.run(
            ["gh", "api", "/copilot_internal/user"],
            capture_output=True,
            text=True,
            check=True,
            timeout=8,
            env=env,
        )
    except (subprocess.SubprocessError, OSError):
        return None

    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None

    write_json(
        CACHE_FILE,
        {
            "fetched_at": time.time(),
            "payload": payload,
        },
    )
    return payload


def get_quota_payload() -> Optional[dict]:
    cached = read_json(CACHE_FILE)
    if isinstance(cached, dict):
        fetched_at = cached.get("fetched_at")
        payload = cached.get("payload")
        if isinstance(fetched_at, (int, float)) and isinstance(payload, dict):
            if time.time() - fetched_at < CACHE_TTL_SECONDS:
                return payload

    fresh = fetch_quota_payload()
    if fresh is not None:
        return fresh

    if isinstance(cached, dict) and isinstance(cached.get("payload"), dict):
        return cached["payload"]
    return None


def get_quota_segment() -> Optional[str]:
    payload = get_quota_payload()
    if not isinstance(payload, dict):
        return None

    snapshots = payload.get("quota_snapshots")
    if not isinstance(snapshots, dict):
        return None

    premium = snapshots.get("premium_interactions")
    if not isinstance(premium, dict):
        return None

    if premium.get("unlimited"):
        return "Quota unlimited"

    entitlement = premium.get("entitlement")
    remaining = premium.get("remaining", premium.get("quota_remaining"))
    if not isinstance(entitlement, int) or entitlement <= 0 or not isinstance(remaining, int):
        return None

    used = max(0, entitlement - remaining)
    pct = (used / entitlement) * 100
    return f"Quota {pct:.0f}%"


def main() -> int:
    preferred_pane_pid = sys.argv[1] if len(sys.argv) > 1 else None
    context_segment = get_context_segment(preferred_pane_pid)
    if not context_segment:
        return 0

    segments = [
        segment
        for segment in (
            context_segment,
            get_quota_segment(),
        )
        if segment
    ]
    if not segments:
        return 0
    print(" | ".join(segments))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
